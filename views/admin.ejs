<%- include('./partials/header') %>
    <div class="w-full min-h-screen flex flex-col gap-10 px-4 py-8 md:flex-row md:px-8 md:py-12">
        <aside class="w-full md:w-[25%] flex flex-col gap-6 rounded-3xl bg-white/90 p-6 shadow-lg border border-slate-200">
            <div class="space-y-3">
                <a class="block rounded-xl bg-slate-100 px-4 py-3 text-slate-800 font-semibold hover:bg-slate-200" href="">All Products</a>
                <a class="block rounded-xl bg-blue-600 px-4 py-3 text-white font-semibold hover:bg-blue-700" href="">Create new product</a>
            </div>
        </aside>

        <main class="w-full md:w-[75%] flex flex-col gap-6">
            <div class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
                <h1 class="text-2xl font-bold text-slate-900">Admin Dashboard</h1>
                <a class="inline-flex items-center justify-center rounded-full bg-red-500 px-4 py-3 text-sm font-semibold text-white hover:bg-red-600" href="">Delete all</a>
            </div>

            <div class="grid gap-5 sm:grid-cols-2 xl:grid-cols-4">
                <% for (let i = 0; i < 8; i++) { %>
                <div class="w-full overflow-hidden rounded-3xl bg-red-500 shadow-xl">
                    <div class="h-52 bg-yellow-500"></div>
                    <div class="flex items-center justify-between gap-4 px-4 py-4 bg-white">
                        <div>
                            <h3 class="font-semibold text-slate-900">Clinge Bag</h3>
                            <h4 class="text-sm text-slate-600">₹ 1200</h4>
                        </div>
                        <a class="flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-slate-800 shadow-sm hover:bg-slate-200" href="">
                            <i class="ri-add-line"></i>
                        </a>
                    </div>
                </div>
                <% } %>
            </div>
        </main>
    </div>
    <%- include('./partials/footer') %>