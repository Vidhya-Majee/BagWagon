<%- include('./partials/header') %>

<div class="w-full min-h-screen bg-gradient-to-br from-slate-100 via-blue-50 to-slate-100 py-10 px-4 md:px-10">
  <div class="mx-auto grid w-full max-w-6xl gap-8 md:grid-cols-[220px_minmax(0,1fr)]">
    <div id="accountSidebarOverlay" class="hidden fixed inset-0 z-40 bg-blue-900/30 md:hidden"></div>

    <!-- Sidebar -->
    <aside id="accountSidebar" class="fixed inset-y-0 left-0 z-50 w-11/12 max-w-xs transform -translate-x-full overflow-y-auto bg-white shadow-2xl ring-1 ring-slate-200 md:static md:translate-x-0 md:inset-auto md:w-full md:max-w-[220px] md:overflow-visible md:shadow-none md:ring-0 md:block md:sticky md:top-6">
      <div class="flex items-center gap-3 bg-gradient-to-r from-blue-700 via-blue-600 to-yellow-500 px-5 py-4 rounded-tr-3xl rounded-br-3xl md:rounded-3xl shadow-xl">
        <i class="ri-user-3-fill text-white text-xl"></i>
        <div>
          <p class="text-xs uppercase tracking-[0.35em] text-blue-100">Account</p>
          <h3 class="text-lg font-extrabold text-white">Dashboard</h3>
        </div>
        <button id="closeAccountSidebar" type="button" class="ml-auto inline-flex h-10 w-10 items-center justify-center rounded-full bg-slate-100 text-slate-700 hover:bg-slate-200 md:hidden">
          <i class="ri-close-line text-xl"></i>
        </button>
      </div>
      <div class="p-5 space-y-4 md:space-y-5">
        <nav class="space-y-2 text-sm font-semibold text-slate-900">
          <a href="/account" class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 transition hover:bg-blue-50 hover:text-blue-700"><i class="ri-profile-line text-blue-500"></i><span>Profile</span></a>
          <a href="/orders" class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 transition hover:bg-blue-50 hover:text-blue-700"><i class="ri-truck-line text-yellow-500"></i><span>Orders</span></a>
          <a href="/wishlist" class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 transition hover:bg-blue-50 hover:text-blue-700"><i class="ri-heart-3-line text-red-400"></i><span>Wishlist</span></a>
          <a href="/cart" class="flex items-center gap-3 rounded-2xl border border-slate-200 bg-slate-50 px-4 py-3 transition hover:bg-blue-50 hover:text-blue-700"><i class="ri-shopping-cart-2-line text-pink-500"></i><span>Cart (<%= cartCount %>)</span></a>
          <a href="/users/logout" class="flex items-center gap-3 rounded-2xl border border-red-200 bg-red-50 px-4 py-3 text-red-700 transition hover:bg-red-100"><i class="ri-logout-box-r-line"></i><span>Logout</span></a>
        </nav>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="space-y-8">
      <div class="flex items-center justify-between gap-4 rounded-3xl border border-slate-200 bg-white px-5 py-4 shadow-sm md:hidden">
        <div>
          <p class="text-sm uppercase tracking-[0.25em] text-slate-500">Account Menu</p>
          <h2 class="text-lg font-bold text-slate-900">Manage your profile</h2>
        </div>
        <button id="openAccountSidebar" type="button" class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-slate-50 px-4 py-2 text-sm font-semibold text-slate-900 shadow-sm hover:bg-slate-100">
          <i class="ri-menu-3-line text-lg"></i>
          Open
        </button>
      </div>

      <section class="overflow-hidden rounded-3xl border border-blue-100 bg-gradient-to-r from-blue-600 to-yellow-400 shadow-2xl text-white">
        <div class="grid gap-6 p-6 md:grid-cols-[auto_1fr] md:items-center md:p-8">
          <div class="flex h-24 w-24 items-center justify-center rounded-3xl bg-white/15 text-white shadow-xl backdrop-blur-sm">
            <i class="ri-user-3-fill text-5xl"></i>
          </div>
          <div class="space-y-3">
            <p class="text-sm uppercase tracking-[0.24em] text-blue-100/85">Welcome back</p>
            <h1 class="text-3xl font-extrabold text-white">Hello, <span class="text-yellow-200"><%= user.fullname || 'My Dear User' %></span></h1>
            <p class="max-w-2xl text-sm leading-6 text-blue-100/85">Keep your account details up to date, review orders, manage your wishlist, and view the contents of your cart.</p>
          </div>
        </div>
        <div class="grid gap-4 border-t border-blue-100 bg-blue-50/80 p-6 md:grid-cols-4 md:p-8">
          <div class="rounded-3xl bg-white p-5 shadow-sm ring-1 ring-blue-100">
            <p class="text-sm uppercase tracking-[0.24em] text-slate-500">Email</p>
            <p class="mt-3 font-semibold text-slate-900"><%= user.email %></p>
          </div>
          <div class="rounded-3xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
            <p class="text-sm uppercase tracking-[0.24em] text-slate-500">Cart items</p>
            <p class="mt-3 font-semibold text-slate-900"><%= cartCount %></p>
          </div>
          <div class="rounded-3xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
            <p class="text-sm uppercase tracking-[0.24em] text-slate-500">Member since</p>
            <p class="mt-3 font-semibold text-slate-900"><%= user.createdAt ? user.createdAt.toDateString() : 'N/A' %></p>
          </div>
          <div class="rounded-3xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
            <p class="text-sm uppercase tracking-[0.24em] text-slate-500">Wishlist</p>
            <p class="mt-3 font-semibold text-slate-900">Quick access</p>
          </div>
        </div>
      </section>

      <section class="grid gap-6 md:grid-cols-2">
        <a href="/orders" class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-lg transition hover:-translate-y-1 hover:shadow-2xl">
          <div class="flex h-14 w-14 items-center justify-center rounded-3xl bg-blue-100 text-blue-700"><i class="ri-truck-line text-2xl"></i></div>
          <h3 class="mt-5 text-xl font-semibold text-slate-900">My Orders</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">View recent purchases, order status, and delivery updates.</p>
        </a>
        <a href="/wishlist" class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-lg transition hover:-translate-y-1 hover:shadow-2xl">
          <div class="flex h-14 w-14 items-center justify-center rounded-3xl bg-pink-100 text-pink-600"><i class="ri-heart-3-line text-2xl"></i></div>
          <h3 class="mt-5 text-xl font-semibold text-slate-900">Wishlist</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">Save products for later and quickly browse favorites.</p>
        </a>
        <a href="/cart" class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-lg transition hover:-translate-y-1 hover:shadow-2xl">
          <div class="flex h-14 w-14 items-center justify-center rounded-3xl bg-yellow-100 text-yellow-700"><i class="ri-shopping-cart-2-line text-2xl"></i></div>
          <h3 class="mt-5 text-xl font-semibold text-slate-900">Cart</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">Review items ready for checkout and update quantity.</p>
        </a>
        <a href="/addresses" class="group rounded-3xl border border-slate-200 bg-white p-6 shadow-lg transition hover:-translate-y-1 hover:shadow-2xl">
          <div class="flex h-14 w-14 items-center justify-center rounded-3xl bg-blue-100 text-blue-700"><i class="ri-map-pin-2-line text-2xl"></i></div>
          <h3 class="mt-5 text-xl font-semibold text-slate-900">Addresses</h3>
          <p class="mt-2 text-sm leading-6 text-slate-600">Manage your saved shipping and billing addresses.</p>
        </a>
      </section>

      <section class="overflow-hidden rounded-3xl border border-slate-200 bg-white p-8 shadow-2xl">
        <div class="flex flex-col gap-6">
          <div class="flex flex-col gap-2 sm:flex-row sm:items-center sm:justify-between">
            <h3 class="text-xl font-extrabold text-blue-700">Profile Details</h3>
            <span class="text-sm text-slate-500">Update your account information anytime</span>
          </div>
          <div class="grid gap-6 md:grid-cols-2">
            <div class="rounded-3xl bg-blue-50 p-5 shadow-sm ring-1 ring-blue-100">
              <p class="text-sm uppercase tracking-[0.24em] text-slate-500">Name</p>
              <p class="mt-3 text-lg font-semibold text-slate-900"><%= user.fullname || 'My Dear User' %></p>
            </div>
            <div class="rounded-3xl bg-yellow-50 p-5 shadow-sm ring-1 ring-yellow-100">
              <p class="text-sm uppercase tracking-[0.24em] text-slate-500">Email</p>
              <p class="mt-3 text-lg font-semibold text-slate-900"><%= user.email %></p>
            </div>
            <div class="rounded-3xl bg-blue-50 p-5 shadow-sm ring-1 ring-blue-100">
              <p class="text-sm uppercase tracking-[0.24em] text-slate-500">Cart Items</p>
              <p class="mt-3 text-lg font-semibold text-slate-900"><%= cartCount %> item(s)</p>
            </div>
            <div class="rounded-3xl bg-yellow-50 p-5 shadow-sm ring-1 ring-yellow-100">
              <p class="text-sm uppercase tracking-[0.24em] text-slate-500">Member Since</p>
              <p class="mt-3 text-lg font-semibold text-slate-900"><%= user.createdAt ? user.createdAt.toDateString() : 'N/A' %></p>
            </div>
          </div>
        </div>
      </section>
    </main>
  </div>
</div>

<style>
@keyframes fade-in {
  from { opacity: 0; transform: translateY(20px); }
  to { opacity: 1; transform: translateY(0); }
}
.animate-fade-in {
  animation: fade-in 0.5s ease;
}
</style>

<script>
  (function() {
    var openSidebarBtn = document.getElementById('openAccountSidebar');
    var closeSidebarBtn = document.getElementById('closeAccountSidebar');
    var sidebar = document.getElementById('accountSidebar');
    var overlay = document.getElementById('accountSidebarOverlay');
    if (!openSidebarBtn || !closeSidebarBtn || !sidebar || !overlay) return;

    function openSidebar() {
      sidebar.classList.remove('-translate-x-full');
      overlay.classList.remove('hidden');
    }
    function closeSidebar() {
      sidebar.classList.add('-translate-x-full');
      overlay.classList.add('hidden');
    }

    openSidebarBtn.addEventListener('click', openSidebar);
    closeSidebarBtn.addEventListener('click', closeSidebar);
    overlay.addEventListener('click', closeSidebar);
  })();
</script>

<%- include('./partials/footer') %>
